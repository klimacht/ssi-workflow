From a0daaee55b0565b6182364da4533b59049b7803b Mon Sep 17 00:00:00 2001
From: author <author@example.org>
Date: Thu May 28 11:55:18 2026 +0200
Subject: [PATCH] Add nearest union mode and configurable derivative sharing

- ProbeVolume_UnionSpheres: add union_mode = nearest (nearest-center
  indicator; identical hard-sphere membership to product mode, faster).
- OrderParametersInterface: add NO_SHARE_ALL_DERIVATIVES flag to suppress
  MPI broadcast of derivatives when biasing via the internal INDUS bias.
---
 src/orderparameters/OrderParametersInterface.cpp | 11 ++++++++++-
 1 file changed, 10 insertions(+), 1 deletion(-)

diff --git a/src/orderparameters/OrderParametersInterface.cpp b/src/orderparameters/OrderParametersInterface.cpp
index 37a91c6..1ac8e3d 100644
--- a/src/orderparameters/OrderParametersInterface.cpp
+++ b/src/orderparameters/OrderParametersInterface.cpp
@@ -24,6 +24,8 @@ void OrderParametersInterface::registerKeywords( Keywords& keys )
   keys.add("compulsory", "INPUTFILE", "order parameters input file");
   keys.add("optional",   "TOL",       "tolerance on the largest norm expected for a derivative");
+  keys.addFlag("NO_SHARE_ALL_DERIVATIVES", false,
+               "do not share all INDUS order-parameter derivatives across MPI ranks");
 
 
 	//----- Output keys -----//
@@ -96,7 +98,7 @@ OrderParametersInterface::OrderParametersInterface(const ActionOptions& ao):
-		driver_ptr_->set_share_all_derivatives(false);
+		driver_ptr_->set_share_all_derivatives( !no_share_all_derivatives );
 	}
