 }
 
+
+void ProbeVolume_UnionSpheres::printRuntimeDebugAndReset(const std::string& context) const
+{
+        if ( mpi_communicator_.get_rank() != 0 ) return;
+
+        double avg_candidates_per_call = 0.0;
+        double avg_distance_checks_per_call = 0.0;
+        double avg_active_contribs_per_call = 0.0;
+        double frac_empty_cells = 0.0;
+        double frac_nonzero_waters = 0.0;
+        double frac_saturated = 0.0;
+
+        if ( cnt_calls_ > 0 ) {
+                avg_candidates_per_call =
+                    static_cast<double>(cnt_candidate_sum_) / static_cast<double>(cnt_calls_);
+                avg_distance_checks_per_call =
+                    static_cast<double>(cnt_distance_checks_) / static_cast<double>(cnt_calls_);
+                avg_active_contribs_per_call =
+                    static_cast<double>(cnt_active_contribs_) / static_cast<double>(cnt_calls_);
+                frac_empty_cells =
+                    static_cast<double>(cnt_empty_cells_) / static_cast<double>(cnt_calls_);
+                frac_nonzero_waters =
+                    static_cast<double>(cnt_nonzero_waters_) / static_cast<double>(cnt_calls_);
+                frac_saturated =
+                    static_cast<double>(cnt_saturated_fastpath_) / static_cast<double>(cnt_calls_);
+        }
+
+        std::cerr << "INDUS union_spheres runtime debug [" << context << "]\n"
+                  << "  update_count = " << update_count_ << "\n"
+                  << "  union_mode = " << union_mode_ << "\n"
+                  << "  calls = " << cnt_calls_ << "\n"
+                  << "  empty_cell_calls = " << cnt_empty_cells_ << "\n"
+                  << "  frac_empty_cells = " << frac_empty_cells << "\n"
+                  << "  candidate_sum = " << cnt_candidate_sum_ << "\n"
+                  << "  avg_candidates_per_call = " << avg_candidates_per_call << "\n"
+                  << "  distance_checks = " << cnt_distance_checks_ << "\n"
+                  << "  avg_distance_checks_per_call = " << avg_distance_checks_per_call << "\n"
+                  << "  active_contribs = " << cnt_active_contribs_ << "\n"
+                  << "  avg_active_contribs_per_call = " << avg_active_contribs_per_call << "\n"
+                  << "  nonzero_waters = " << cnt_nonzero_waters_ << "\n"
+                  << "  frac_nonzero_waters = " << frac_nonzero_waters << "\n"
+                  << "  saturated_fastpath = " << cnt_saturated_fastpath_ << "\n"
+                  << "  frac_saturated_fastpath = " << frac_saturated << "\n";
+
+        cnt_calls_ = 0;
+        cnt_empty_cells_ = 0;
+        cnt_candidate_sum_ = 0;
+        cnt_distance_checks_ = 0;
+        cnt_active_contribs_ = 0;
+        cnt_saturated_fastpath_ = 0;
+        cnt_nonzero_waters_ = 0;
+}
