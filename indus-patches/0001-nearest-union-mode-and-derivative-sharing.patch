From 3d651354d2956012ce90a7d14283be76167a89ab Mon Sep 17 00:00:00 2001
From: tklimach <tklimach@local>
Date: Fri, 29 May 2026 10:08:37 +0200
Subject: [PATCH 4/4] Skip zero INDUS derivatives when passing to PLUMED

---
 .../OrderParametersInterface.cpp              | 38 ++++++++++++++-----
 1 file changed, 28 insertions(+), 10 deletions(-)

diff --git a/src/orderparameters/OrderParametersInterface.cpp b/src/orderparameters/OrderParametersInterface.cpp
index 1ac8e3d..f53b11c 100644
--- a/src/orderparameters/OrderParametersInterface.cpp
+++ b/src/orderparameters/OrderParametersInterface.cpp
@@ -275,11 +275,20 @@ void OrderParametersInterface::calculate()
 	ntilde_ptr->set(ntilde_v_);
 	if ( ntilde_ptr->hasDerivatives() ) {
 		for ( int i=0; i<num_op_atoms; i++ ) {
-			// PLUMED stores derivatives in a linear array
-			int atom_offset = DIM_*i;
-			for ( int d=0; d<DIM_; ++d ) {
-				ntilde_ptr->addDerivative(atom_offset + d, derivatives_ntilde_v[i][d]);
-			}
+		        const double dx = derivatives_ntilde_v[i][0];
+		        const double dy = derivatives_ntilde_v[i][1];
+		        const double dz = derivatives_ntilde_v[i][2];
+
+		        // Skip atoms with exactly zero derivative.
+		        // Most target waters are far from the probe volume.
+		        if ( dx == 0.0 && dy == 0.0 && dz == 0.0 ) {
+		                continue;
+		        }
+
+		        int atom_offset = DIM_*i;
+		        ntilde_ptr->addDerivative(atom_offset + 0, dx);
+		        ntilde_ptr->addDerivative(atom_offset + 1, dy);
+		        ntilde_ptr->addDerivative(atom_offset + 2, dz);
 		}
 		setBoxDerivatives(ntilde_ptr, box_derivatives_ntilde_v_);
 	}
@@ -308,11 +317,20 @@ void OrderParametersInterface::calculate()
 	ubias_ptr->set(u_bias_);
 	if ( ubias_ptr->hasDerivatives() ) {
 		for ( int i=0; i<num_op_atoms; i++ ) {
-			// PLUMED stores derivatives in a linear array
-			int atom_offset = DIM_*i;
-			for ( int d=0; d<DIM_; ++d ) {
-				ubias_ptr->addDerivative(atom_offset + d, derivatives_u_bias_total[i][d]);
-			}
+		        const double dx = derivatives_u_bias_total[i][0];
+		        const double dy = derivatives_u_bias_total[i][1];
+		        const double dz = derivatives_u_bias_total[i][2];
+
+		        // Skip atoms with exactly zero derivative.
+		        // Avoid hundreds of thousands of no-op PLUMED derivative insertions per step.
+		        if ( dx == 0.0 && dy == 0.0 && dz == 0.0 ) {
+		                continue;
+		        }
+
+		        int atom_offset = DIM_*i;
+		        ubias_ptr->addDerivative(atom_offset + 0, dx);
+		        ubias_ptr->addDerivative(atom_offset + 1, dy);
+		        ubias_ptr->addDerivative(atom_offset + 2, dz);
 		}
 		setBoxDerivatives(ubias_ptr, box_derivatives_u_bias_);
 	}
-- 
