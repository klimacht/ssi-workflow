         has_input_box_lengths_ = input_parameter_pack.readArray("box_lengths", KeyType::Optional, input_box_lengths_);
 
+        input_parameter_pack.readString("union_mode", KeyType::Optional, union_mode_);
+        if ( union_mode_ != "product" && union_mode_ != "nearest" ) {
+                std::stringstream ss;
+                ss << "ProbeVolume_UnionSpheres: unknown union_mode '" << union_mode_
+                   << "'. Valid options are 'product' and 'nearest'.";
+                throw std::runtime_error(ss.str());
+        }
+
         input_parameter_pack.readString("centers_file", KeyType::Required, centers_file_);
 
         readCentersFile(centers_file_);
@@ -291,6 +299,60 @@ void ProbeVolume_UnionSpheres::calculateIndicator(
 
         const std::vector<int>& candidates = cell_candidates_[cell_id];
 
+        const double r_search_sq = r_search_ * r_search_;
+
+        // Fast approximate/surface-distance mode:
+        // For a hard union of equal spheres, membership is exactly determined by
+        // the nearest center. Here we also define the smooth indicator from the
+        // nearest-center distance only. This is much faster than product mode.
+        if ( union_mode_ == "nearest" ) {
+                double min_dist_sq = r_search_sq;
+                bool found = false;
+                Real3 x_center_min;
+
+                for ( int center_index : candidates ) {
+                        const Real3& c = centers_[center_index];
+
+                        double dist_sq;
+                        Real3 x_center_i;
+                        simulation_box_.calculateDistance(c, x, x_center_i, dist_sq);
+
+                        if ( dist_sq <= min_dist_sq ) {
+                                min_dist_sq = dist_sq;
+                                x_center_min = x_center_i;
+                                found = true;
+                        }
+                }
+
+                if ( !found ) {
+                        h_v = 0.0;
+                        htilde_v = 0.0;
+                        for ( int d=0; d<DIM_; ++d ) dhtilde_v_dx[d] = 0.0;
+                        region = RegionEnum::Unimportant;
+                        return;
+                }
+
+                double dist = std::sqrt(min_dist_sq);
+                double dht_dr = 0.0;
+
+                switching_function_r_shell_.calculate(
+                        dist, need_derivatives_, h_v, htilde_v, dht_dr, region
+                );
+
+                if ( need_derivatives_ ) {
+                        if ( htilde_v > 0.0 && dist > 0.0 ) {
+                                double pref = dht_dr / dist;
+                                for ( int d=0; d<DIM_; ++d ) {
+                                        dhtilde_v_dx[d] = pref * x_center_min[d];
+                                }
+                        } else {
+                                for ( int d=0; d<DIM_; ++d ) dhtilde_v_dx[d] = 0.0;
+                        }
+                }
+
+                return;
+        }
+
         double prod_not = 1.0;
 
         std::vector<double> htilde_list;
@@ -300,8 +362,6 @@ void ProbeVolume_UnionSpheres::calculateIndicator(
         bool any_inside_nominal = false;
         bool any_nonzero_smooth = false;
 
-        const double r_search_sq = r_search_ * r_search_;
-
         for ( int center_index : candidates ) {
                 const Real3& c = centers_[center_index];
 
@@ -431,6 +491,7 @@ void ProbeVolume_UnionSpheres::printGridDebugSummary(const std::string& context)
                   << "  grid_build_count = " << grid_build_count_ << "\\n"
                   << "  box_lengths = {"
                   << lengths[0] << ", " << lengths[1] << ", " << lengths[2] << "} nm\\n"
+                  << "  union_mode = " << union_mode_ << "\\n"
                   << "  cell_size_requested = " << cell_size_requested_ << " nm\\n"
                   << "  max_cells_per_dim = " << max_cells_per_dim_ << "\\n"
                   << "  has_input_box_lengths = " << has_input_box_lengths_ << "\\n"
@@ -485,6 +546,7 @@ std::string ProbeVolume_UnionSpheres::getInputSummary(const std::string& prepend
            << prepend_string << "  n_centers = " << centers_.size() << "\n"
            << prepend_string << "  r_min = " << r_min_ << " [nm]\n"
            << prepend_string << "  r_max = " << r_max_ << " [nm]\n"
+           << prepend_string << "  union_mode = " << union_mode_ << "\n"
            << prepend_string << "  Cell candidate grid\n"
            << prepend_string << "    cell_size_requested = " << cell_size_requested_ << " [nm]\n"
            << prepend_string << "    r_search = " << r_search_ << " [nm]\n"
diff --git a/src/orderparameters/ProbeVolume_UnionSpheres.h b/src/orderparameters/ProbeVolume_UnionSpheres.h
index 036c093..dff3365 100644
--- a/src/orderparameters/ProbeVolume_UnionSpheres.h
+++ b/src/orderparameters/ProbeVolume_UnionSpheres.h
@@ -69,6 +69,7 @@ class ProbeVolume_UnionSpheres : public ProbeVolume
 
